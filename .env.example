APP_NAME=Thynk
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
APP_VERSION=1.0.0
PRODUCTION_SERVER_URL=https://api.thynk.app

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=thynk

JWT_SECRET_KEY=change-me
JWT_REFRESH_SECRET_KEY=change-me-too
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_LIMIT=5
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@thynk.app
BREVO_SENDER_NAME=Thynk

AI_PROVIDER=azure_openai
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=portfolio-assistant
AZURE_OPENAI_MODEL_NAME=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-04-01-preview
AZURE_OPENAI_MAX_TOKENS=1600

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_BASE_URL=https://api.paystack.co

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push/send

FRONTEND_URL=http://localhost:3000
